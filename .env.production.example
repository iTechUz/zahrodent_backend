# Server & Environment
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
TZ=Asia/Tashkent

# CORS_ORIGINS: Komma bilan ajratilgan ruxsat etilgan domenlar ro'yxati
# MASALAN: CORS_ORIGINS=https://app.zahrodental.uz,https://admin.zahrodental.uz
CORS_ORIGINS=

# PUBLIC_BASE_URL: Backendning tashqi ko'rinadigan manzili
PUBLIC_BASE_URL=https://api.zahrodental.uz

# Database (Prisma)
# PRODUCTIONDA: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=

# Authentication
# PRODUCTIONDA: Kamida 32 belgidan iborat tasodifiy qator yarating
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Initial Seeding (Faqat birinchi marta ishlatiladi)
INITIAL_ADMIN_PHONE=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_NAME="Admin"

# SMS Service (Eskiz.uz)
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# Feature Flags
SWAGGER_ENABLED=false
TELEGRAM_BOT_TOKEN=
TRUST_PROXY=1
