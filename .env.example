# --- Ma'lumotlar bazasi ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zahro_dental?schema=public"

# --- JWT ---
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="7d"

# --- Hujjatlar ---
# REST API: docs/API.md  |  Testlar: docs/TESTING.md  |  E2E: npm run test:e2e (seed talab)

# --- Server (lokal va production) ---
# Tinglash porti (Railway/Heroku ko'pincha PORT ni o'zi beradi)
PORT=3000

# Qaysi manzilda tinglash: VPS/Docker uchun 0.0.0.0 (default), faqat lokal uchun 127.0.0.1
HOST=0.0.0.0

# Brauzer/log uchun tashqi manzil (nginx HTTPS ortida majburiy)
# Masalan: https://api.sizning-domen.uz
# Bo'lmasa logda http://localhost:PORT ko'rsatiladi
# PUBLIC_BASE_URL=

# --- CORS (frontend domenlari, vergul bilan) ---
# Production: majburiy tavsiya — frontend URL lari
# CORS_ORIGINS=https://app.example.com,https://www.example.com
# Lokal (Vite 5173): quyidagicha yoki CORS_ORIGINS ni bo'sh qoldiring (dev: barcha origin ruxsat)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Swagger UI ---
# Yo'l: /swagger  (eski /docs 301 bilan /swagger ga yo'naltiriladi)
# Production'da default o'chirilgan; serverda ham kerak bo'lsa:
# SWAGGER_ENABLED=true

# --- Reverse proxy (nginx) ---
# X-Forwarded-* sarlavhalarini ishonchli qabul qilish
# TRUST_PROXY=1

# --- Eskiz.uz SMS (ixtiyoriy) ---
# https://eskiz.uz kabinetidan email/parol. Sozlanmasa SMS faqat DB ga yoziladi (simulyatsiya).
# ESKIZ_BASE_URL=https://notify.eskiz.uz
# ESKIZ_EMAIL=your@email.uz
# ESKIZ_PASSWORD=your_api_password
# Jo'natuvchi nomi (kabinetda ko'rsatilgan, masalan 4546)
# ESKIZ_FROM=4546

# --- Muhit ---
# NODE_ENV=production

# --- Dastlabki (Initial) Admin / Super Admin ---
# Tizim birinchi marta ishga tushganda yoki seed qilinganda yaratiladigan admin.
# PRODUCTIONda bularni ALBATTA o'zgartiring va .env faylga yozing.
INITIAL_ADMIN_PHONE="+998901234567"
INITIAL_ADMIN_PASSWORD="admin_strong_password"
INITIAL_ADMIN_NAME="Dr. Zahro Admin"

# --- Telegram Bot (Murojaatlar qabuli uchun) ---
TELEGRAM_BOT_TOKEN="123456789:ABCDEF..."
