generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  passwordHash String   @map("password_hash")
  role         String
  specialty    String?
  avatar       String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  doctor   Doctor?
  comments PatientComment[]

  @@map("users")
}

model Patient {
  id               String   @id @default(cuid())
  firstName        String   @map("first_name")
  lastName         String   @map("last_name")
  age              Int
  phone            String
  address          String   @default("")
  workplace        String   @default("")
  source           String
  notes            String   @default("")
  avatar           String?
  createdAt        DateTime @default(now()) @map("created_at") @db.Date
  toothChart       Json?    @map("tooth_chart")

  assignedDoctorId String?  @map("assigned_doctor_id")
  assignedDoctor   Doctor?  @relation("AssignedDoctor", fields: [assignedDoctorId], references: [id])

  bookings      Booking[]
  visits        Visit[]
  payments      Payment[]
  notifications Notification[]
  comments      PatientComment[]

  @@index([createdAt])
  @@index([phone])
  @@index([lastName, firstName])
  @@map("patients")
}

model Doctor {
  id        String  @id @default(cuid())
  firstName String  @map("first_name") @default("")
  lastName  String  @map("last_name") @default("")
  specialty String
  phone     String
  avatar    String?
  schedule  Json?
  daysOff   Json?   @map("days_off")

  bookings      Booking[]
  visits        Visit[]
  notifications Notification[]
  user          User?          @relation(fields: [userId], references: [id])
  userId        String?        @unique @map("user_id")

  assignedPatients Patient[] @relation("AssignedDoctor")

  @@map("doctors")
}

model Service {
  id          String  @id @default(cuid())
  name        String
  category    String
  price       Int
  duration    Int
  description String?

  bookings Booking[]
  payments Payment[]

  @@map("services")
}

model Booking {
  id             String    @id @default(cuid())
  patientId      String    @map("patient_id")
  doctorId       String    @map("doctor_id")
  date           DateTime  @db.Date
  time           String
  source         String
  status         String
  notes          String    @default("")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Date
  serviceId      String?   @map("service_id")
  reminderSentAt DateTime? @map("reminder_sent_at")

  patient Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor   @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  visits Visit[]

  @@index([patientId])
  @@index([doctorId])
  @@index([date])
  @@index([status])
  @@index([date, status])
  @@map("bookings")
}

model Visit {
  id        String   @id @default(cuid())
  patientId String   @map("patient_id")
  doctorId  String   @map("doctor_id")
  bookingId String?  @map("booking_id")
  date      DateTime @db.Date
  status    String
  price     Int      @default(0)
  diagnosis String   @default("")
  treatment String   @default("")
  notes     String   @default("")

  patient  Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor   Doctor    @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  booking  Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  payments Payment[]

  @@map("visits")
}

model Payment {
  id          String   @id @default(cuid())
  patientId   String   @map("patient_id")
  amount      Int
  method      String
  status      String
  type        String   @default("INCOME") // INCOME (Kirim) or EXPENSE (Chiqim)
  date        DateTime @db.Date
  description String
  discount    Int?
  serviceId   String?  @map("service_id")
  visitId     String?  @map("visit_id")

  patient Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  visit   Visit?   @relation(fields: [visitId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([status])
  @@index([date])
  @@index([type])
  @@map("payments")
}

model PatientComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  patientId String   @map("patient_id")
  authorId  String   @map("author_id")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("patient_comments")
}

model Notification {
  id        String   @id @default(cuid())
  patientId String?  @map("patient_id")
  doctorId  String?  @map("doctor_id")
  type      String
  message   String
  sentAt    DateTime @map("sent_at")
  status    String

  patient Patient? @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor?  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String
  service   String?
  message   String?
  status    String   @default("new") // new, contacted, consultation, proposal, converted, cancelled
  source    String   @default("telegram_bot")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt])
  @@map("leads")
}
