{
	"compilerOptions": {
		"module": "commonjs",
		"declaration": true,
		"removeComments": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"allowSyntheticDefaultImports": true,
		"target": "ES2021",
		"sourceMap": true,
		"outDir": "./dist",
		"baseUrl": "./",
		"incremental": true,
		"strict": false,
		"noImplicitAny": false,
		"strictPropertyInitialization": false,
		"skipLibCheck": true,
		"rootDir": "./",
		"moduleResolution": "node",
		"paths": {
			"src/*": ["src/*"],
			"@/*": ["src/*"],
			"@app/*": ["src/*"],
			"@prisma/*": ["src/prisma/*"]
		  }
	},
	"include": ["src/**/*", "prisma/**/*"],
	"exclude": ["node_modules", "dist", "test"]
}
